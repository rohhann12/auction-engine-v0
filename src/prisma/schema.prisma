generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url="postgresql://postgres:postgres@localhost:5432/trace"
}

enum Roles{
  buyer
  seller
}

enum Status{
  ORDER_ACCEPTED
  ORDER_REJECTED
  ORDER_PENDING
}
model user{
  id String  @unique @default(uuid()) @id
  bids String[] 
  orders  String[]
  active Boolean
  userBids bids[]
  role Roles
  isOwner Boolean @default(false)
}

model bids{
  id String @unique @default(uuid()) @id
  roomId String 
  price   Int 
  userActivity  user?  @relation(fields:[userId],references:[id]) 
  userId String
  status Status
}


model product{
  roomId String @unique @default(uuid()) @id
  minPrice Int
  ownerId  String
  soldForPrice Int
  auctionStartsAt DateTime?
  auctionEndsAt DateTime?
  images        String?
}
